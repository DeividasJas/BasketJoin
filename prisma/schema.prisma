// This is your Prisma schema file
// Works for both development (local PostgreSQL) and production (Prisma Postgres)
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  PLAYER
  ADMIN
  ORGANIZER
}

enum GameStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
  IN_PROGRESS
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
  WAITLIST
}

enum LeagueStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ScheduleType {
  RECURRING
  CUSTOM
}

enum MembershipStatus {
  ACTIVE
  PENDING_PAYMENT
  EXPIRED
  CANCELLED
}

enum PaymentScheduleStatus {
  PENDING
  PAID
  OVERDUE
  PARTIALLY_PAID
}

enum PaymentType {
  MEMBERSHIP_FEE
  GUEST_FEE
  REBATE
}

enum RegistrationType {
  MEMBER
  GUEST
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application models
model Users {
  id                 String               @id @default(cuid())
  email              String?              @unique
  emailVerified      DateTime?
  password           String?
  family_name        String?
  given_name         String?
  username           String?
  phone_number       String?
  picture            String?
  role               UserRole             @default(PLAYER)
  is_active          Boolean              @default(true)
  created_at         DateTime             @default(now())
  modified_at        DateTime             @updatedAt
  game_registrations Game_registrations[]
  accounts           Account[]
  sessions           Session[]
  organized_games    Games[]              @relation("GameOrganizer")
  notifications      Notification[]
  memberships        LeagueMembership[]
  payments           Payment[]
}

model Games {
  id                 Int                  @id @default(autoincrement())
  game_date          DateTime
  location_id        Int
  max_players        Int?
  min_players        Int                  @default(10)
  status             GameStatus           @default(SCHEDULED)
  description        String?
  organizer_id       String?
  game_type          String?
  league_id          String?
  created_at         DateTime             @default(now())
  modified_at        DateTime             @updatedAt
  game_registrations Game_registrations[]
  notifications      Notification[]

  location  Locations @relation(fields: [location_id], references: [id])
  organizer Users?    @relation("GameOrganizer", fields: [organizer_id], references: [id])
  league    League?   @relation(fields: [league_id], references: [id], onDelete: SetNull)

  @@unique([game_date, location_id])
  @@index([league_id])
}

model Game_registrations {
  id                String             @id @default(cuid())
  user_id           String
  game_id           Int
  status            RegistrationStatus @default(CONFIRMED)
  registration_type RegistrationType   @default(GUEST)
  guest_fee_paid    Boolean            @default(false)
  created_at        DateTime           @default(now())
  modified_at       DateTime           @updatedAt

  user Users @relation(fields: [user_id], references: [id])
  game Games @relation(fields: [game_id], references: [id])

  @@unique([user_id, game_id])
}

model Locations {
  id             Int      @id @default(autoincrement())
  name           String
  address        String
  city           String
  description    String?
  capacity       Int?
  court_count    Int      @default(1)
  image_url      String?
  price_per_game Int?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  modified_at    DateTime @updatedAt
  games          Games[]
  leagues        League[]
}

model Notification {
  id         String   @id @default(cuid())
  user_id    String
  game_id    Int?
  type       String
  message    String
  read       Boolean  @default(false)
  created_at DateTime @default(now())

  user Users  @relation(fields: [user_id], references: [id])
  game Games? @relation(fields: [game_id], references: [id])
}

// League System - Combines Series + Season

model League {
  id                 String         @id @default(uuid())
  name               String
  description        String?
  location_id        Int

  // Time boundaries
  start_date         DateTime
  end_date           DateTime
  status             LeagueStatus   @default(UPCOMING)

  // Payment settings
  gym_rental_cost    Int // In cents
  guest_fee_per_game Int // In cents
  payment_due_dates  String // JSON array of ISO dates

  // Game settings
  min_players        Int            @default(10)
  max_players        Int?
  game_type          String?
  game_description   String?

  // Schedule configuration
  schedule_type      ScheduleType   @default(CUSTOM)
  recurring_pattern  String? // JSON: {frequency: "WEEKLY", dayOfWeek: 1, time: "19:00"}
  custom_dates       String? // JSON array of ISO date strings

  // Timestamps
  created_at         DateTime       @default(now())
  modified_at        DateTime       @updatedAt

  // Relations
  location           Locations          @relation(fields: [location_id], references: [id])
  games              Games[]
  memberships        LeagueMembership[]
  payments           Payment[]
  payment_schedules  PaymentSchedule[]

  @@index([location_id])
  @@index([status])
  @@index([start_date])
  @@index([end_date])
}

model LeagueMembership {
  id               String           @id @default(uuid())
  user_id          String
  league_id        String
  status           MembershipStatus @default(ACTIVE)
  joined_at        DateTime         @default(now())
  pro_rated_amount Int // Total amount member owes (pro-rated from join date) in cents
  created_at       DateTime         @default(now())
  modified_at      DateTime         @updatedAt

  user              Users               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  league            League              @relation(fields: [league_id], references: [id], onDelete: Cascade)
  payment_schedules PaymentSchedule[]
  payments          Payment[]

  @@unique([user_id, league_id])
  @@index([user_id])
  @@index([league_id])
  @@index([status])
}

model PaymentSchedule {
  id            String                 @id @default(uuid())
  league_id     String
  membership_id String
  due_date      DateTime
  amount_due    Int // In cents - calculated based on pro-rating
  amount_paid   Int                    @default(0) // In cents - tracks partial payments
  status        PaymentScheduleStatus  @default(PENDING)
  notes         String?
  created_at    DateTime               @default(now())
  modified_at   DateTime               @updatedAt
  paid_at       DateTime?

  league     League           @relation(fields: [league_id], references: [id], onDelete: Cascade)
  membership LeagueMembership @relation(fields: [membership_id], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@index([league_id])
  @@index([membership_id])
  @@index([due_date])
  @@index([status])
}

model Payment {
  id                  String      @id @default(uuid())
  user_id             String
  league_id           String
  membership_id       String?
  payment_schedule_id String?
  payment_type        PaymentType
  amount              Int // In cents
  payment_method      String? // BANK_TRANSFER, CASH, OTHER
  payment_date        DateTime    @default(now())
  notes               String?
  created_at          DateTime    @default(now())

  user             Users                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  league           League               @relation(fields: [league_id], references: [id], onDelete: Cascade)
  membership       LeagueMembership?    @relation(fields: [membership_id], references: [id], onDelete: SetNull)
  payment_schedule PaymentSchedule?     @relation(fields: [payment_schedule_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([league_id])
  @@index([membership_id])
  @@index([payment_type])
  @@index([payment_date])
}
