# ===================================
# DATABASE CONFIGURATION
# ===================================
# Neon Postgres (pooled connection for runtime queries)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Neon Postgres (direct connection for Prisma migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
#
# For local development, override in .env.local:
#   DATABASE_URL="postgresql://basketjoin:basketjoin_dev_password@localhost:5432/basketjoin_dev"

# ===================================
# NEXTAUTH.JS
# ===================================
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ===================================
# OAUTH PROVIDERS
# ===================================
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Facebook OAuth — https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ===================================
# DOCKER POSTGRESQL CONFIGURATION
# ===================================
# These values are used by docker-compose.yml
POSTGRES_USER=basketjoin
POSTGRES_PASSWORD=basketjoin_dev_password
POSTGRES_DB=basketjoin_dev
